# Environment variables for STAL development

# Vercel Deployment (optional)
# NEXT_PUBLIC_SITE_URL=https://stal.vercel.app

# Analytics (Phase 5 - future)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Shopify Integration (Phase 4 - future)
# NEXT_PUBLIC_SHOPIFY_STORE_URL=
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Stripe Payment Integration (Phase 4 - future)
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=

# 3D Model/Three.js CDN (Phase 3 - future)
# NEXT_PUBLIC_MODEL_CDN_URL=
